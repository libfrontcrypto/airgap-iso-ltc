{
  "name": "@libfrontcrypto/airgap-iso-ltc",
  "version": "1.0.2-dev.1",
  "description": "Litecoin isolated module for AirGap Wallet and Vault",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "sign": "tsx scripts/sign-module.ts",
    "browserify": "browserify ./dist/index.js -s litecoinModule -o ./module/index.js && npm run sanitize-bundle",
    "sanitize-bundle": "tsx scripts/sanitize-bundle.ts",
    "package": "tsx scripts/package-module.ts",
    "bundle": "npm run build && npm run browserify && npm run sign && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/libfrontcrypto/airgap-iso-ltc"
  },
  "keywords": [
    "airgap",
    "litecoin",
    "isolated-module",
    "wallet",
    "vault"
  ],
  "author": "libfrontcrypto",
  "license": "GPL-3.0-only",
  "dependencies": {
    "@airgap/coinlib-core": "0.13.19",
    "@airgap/crypto": "0.13.19",
    "@airgap/module-kit": "0.13.19",
    "@airgap/serializer": "0.13.19",
    "@noble/hashes": "^1.4.0",
    "@noble/secp256k1": "^2.0.0",
    "@scure/base": "^1.2.0",
    "@scure/bip32": "^1.7.0",
    "browserify": "^16.5.0",
    "bs58check": "^4.0.0"
  },
  "devDependencies": {
    "@noble/ed25519": "^2.2.3",
    "esbuild": "^0.19.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.3"
  }
}
